@startuml
title Notification Service – Component Diagram (AWS)

package "Client Layer" {
    [API Client]
    [PyQt6 Desktop App]
}

package "Backend" {
    [FastAPI Service]
    [AwsSNSService]
    [AwsSQS Consumer]
}

package "AWS Cloud" {
    [SNS Topic]
    [Main SQS Queue]
    [DLQ]
}

[API Client] --> [FastAPI Service] : HTTP POST /notifications

[FastAPI Service] --> [AwsSNSService] : publish(subject, message)\n(retries)

[AwsSNSService] --> [SNS Topic] : SNS Publish
[SNS Topic] --> [Main SQS Queue] : subscription

[PyQt6 Desktop App] --> [AwsSQS Consumer] : HTTP GET /mock-sqs/receive
[AwsSQS Consumer] --> [Main SQS Queue] : receive/delete\n(with retries)

[Main SQS Queue] --> [DLQ] : redrive on maxReceiveCount

@enduml
